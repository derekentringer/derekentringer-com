generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id                 String                       @id @default(uuid())
  title              String
  content            String
  folder             String?
  folderId           String?
  folderRef          Folder?                      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags               Json                         @default("[]")
  summary            String?
  sortOrder          Int                          @default(0)
  embedding          Unsupported("vector(512)")?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  deletedAt          DateTime?

  @@index([folder])
  @@index([folderId])
  @@index([deletedAt])
  @@index([sortOrder])
  @@map("notes")
}

model Setting {
  id        String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("settings")
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("FolderTree")
  notes     Note[]
  createdAt DateTime @default(now())

  @@unique([parentId, name])
  @@index([parentId])
  @@map("folders")
}

model SyncCursor {
  deviceId     String   @id
  lastSyncedAt DateTime

  @@map("sync_cursors")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("refresh_tokens")
}
