generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  displayName        String?
  role               String    @default("user")
  totpSecret         String?
  totpEnabled        Boolean   @default(false)
  backupCodes        Json      @default("[]")
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  notes              Note[]
  folders            Folder[]
  images             Image[]
  refreshTokens      RefreshToken[]
  passkeys           Passkey[]
  chatMessages       ChatMessage[]
  tombstones         EntityTombstone[]

  @@map("users")
}

model Passkey {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   Json      @default("[]")
  deviceType   String?
  backedUp     Boolean   @default(false)
  friendlyName String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Note {
  id                 String                       @id @default(uuid())
  userId             String
  title              String
  content            String
  folder             String?
  folderId           String?
  folderRef          Folder?                      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags               Json                         @default("[]")
  summary            String?
  favorite           Boolean                      @default(false)
  sortOrder          Int                          @default(0)
  favoriteSortOrder  Int                          @default(0)
  isLocalFile        Boolean                      @default(false)
  audioMode          String?
  transcript         String?
  embedding          Unsupported("vector(512)")?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  deletedAt          DateTime?
  outgoingLinks      NoteLink[]                   @relation("OutgoingLinks")
  incomingLinks      NoteLink[]                   @relation("IncomingLinks")
  versions           NoteVersion[]
  images             Image[]
  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folder])
  @@index([folderId])
  @@index([deletedAt])
  @@index([sortOrder])
  @@index([favoriteSortOrder])
  @@index([updatedAt])
  // Phase 4.1: covers the sync-pull hot path which filters by userId
  // and ranges on updatedAt (plus id for keyset tie-break). Postgres
  // can only pick one index per scan so the composite form matters.
  @@index([userId, updatedAt])
  @@map("notes")
}

model NoteVersion {
  id        String   @id @default(uuid())
  noteId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
  @@map("note_versions")
}

model NoteLink {
  id           String   @id @default(uuid())
  sourceNoteId String
  targetNoteId String
  linkText     String
  createdAt    DateTime @default(now())
  sourceNote   Note     @relation("OutgoingLinks", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote   Note     @relation("IncomingLinks", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@unique([sourceNoteId, targetNoteId, linkText])
  @@index([sourceNoteId])
  @@index([targetNoteId])
  @@map("note_links")
}

model Setting {
  id        String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("settings")
}

model Folder {
  id          String    @id @default(uuid())
  userId      String
  name        String
  parentId    String?
  sortOrder   Int       @default(0)
  favorite    Boolean   @default(false)
  // True when this folder is backed by an on-disk directory managed by a
  // desktop instance. Drives hard-delete semantics on the server REST path
  // (see sync hardening Phase 1) and is the authority the web UI reads to
  // warn users about on-disk consequences.
  isLocalFile Boolean   @default(false)
  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Folder[]  @relation("FolderTree")
  notes       Note[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Uniqueness enforced by partial indexes in migration 20260312100000
  // (excludes soft-deleted rows): folders_root_name_key and
  // folders_userId_parentId_name_key
  @@index([userId])
  @@index([parentId])
  @@index([deletedAt])
  @@index([updatedAt])
  // Phase 4.1: sync-pull filter+range composite.
  @@index([userId, updatedAt])
  @@map("folders")
}

model SyncCursor {
  userId       String
  deviceId     String
  lastSyncedAt DateTime

  @@id([userId, deviceId])
  @@map("sync_cursors")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Image {
  id            String    @id @default(uuid())
  noteId        String
  userId        String
  filename      String
  mimeType      String
  sizeBytes     Int
  r2Key         String    @unique
  r2Url         String
  altText       String    @default("")
  aiDescription String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  note          Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
  @@index([updatedAt])
  @@index([deletedAt])
  // Phase 4.1: sync-pull filter+range composite.
  @@index([userId, updatedAt])
  @@map("images")
}

/// Tombstone for a hard-deleted entity so clients still learn about the
/// deletion on their next `/sync/pull`. Used for folders (all deletes —
/// folders have no restore UI) and for isLocalFile notes (the sync-push
/// path hard-deletes these to prevent zombie entries when the on-disk
/// file is gone). Regular-note soft-deletes are NOT tombstoned — the
/// web trash/restore UX depends on deletedAt-marked rows.
///
/// Sweep (Phase 4 housekeeping): after every active sync_cursor has
/// advanced past `deletedAt`, the tombstone is safe to purge.
model EntityTombstone {
  id         String   @id @default(uuid())
  userId     String
  entityType String // "folder" | "note"
  entityId   String
  deletedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One tombstone per entity — if a delete is somehow re-emitted we just
  // update the existing row's timestamp rather than piling up rows.
  @@unique([userId, entityId])
  @@index([userId, deletedAt])
  @@index([deletedAt])
  @@map("entity_tombstones")
}

model ChatMessage {
  id          String   @id @default(uuid())
  userId      String
  role        String
  content     String   @default("")
  sources     Json?
  meetingData Json?
  noteCards   Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}
