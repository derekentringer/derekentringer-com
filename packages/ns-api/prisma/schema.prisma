generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  displayName        String?
  role               String    @default("user")
  totpSecret         String?
  totpEnabled        Boolean   @default(false)
  backupCodes        Json      @default("[]")
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  notes              Note[]
  folders            Folder[]
  images             Image[]
  refreshTokens      RefreshToken[]
  passkeys           Passkey[]

  @@map("users")
}

model Passkey {
  id           String    @id @default(uuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   Json      @default("[]")
  deviceType   String?
  backedUp     Boolean   @default(false)
  friendlyName String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Note {
  id                 String                       @id @default(uuid())
  userId             String
  title              String
  content            String
  folder             String?
  folderId           String?
  folderRef          Folder?                      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags               Json                         @default("[]")
  summary            String?
  favorite           Boolean                      @default(false)
  sortOrder          Int                          @default(0)
  favoriteSortOrder  Int                          @default(0)
  isLocalFile        Boolean                      @default(false)
  audioMode          String?
  embedding          Unsupported("vector(512)")?
  embeddingUpdatedAt DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  deletedAt          DateTime?
  outgoingLinks      NoteLink[]                   @relation("OutgoingLinks")
  incomingLinks      NoteLink[]                   @relation("IncomingLinks")
  versions           NoteVersion[]
  images             Image[]
  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folder])
  @@index([folderId])
  @@index([deletedAt])
  @@index([sortOrder])
  @@index([favoriteSortOrder])
  @@index([updatedAt])
  @@map("notes")
}

model NoteVersion {
  id        String   @id @default(uuid())
  noteId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
  @@map("note_versions")
}

model NoteLink {
  id           String   @id @default(uuid())
  sourceNoteId String
  targetNoteId String
  linkText     String
  createdAt    DateTime @default(now())
  sourceNote   Note     @relation("OutgoingLinks", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote   Note     @relation("IncomingLinks", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@unique([sourceNoteId, targetNoteId, linkText])
  @@index([sourceNoteId])
  @@index([targetNoteId])
  @@map("note_links")
}

model Setting {
  id        String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("settings")
}

model Folder {
  id        String    @id @default(uuid())
  userId    String
  name      String
  parentId  String?
  sortOrder Int       @default(0)
  favorite  Boolean   @default(false)
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]  @relation("FolderTree")
  notes     Note[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, parentId, name])
  @@index([userId])
  @@index([parentId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("folders")
}

model SyncCursor {
  userId       String
  deviceId     String
  lastSyncedAt DateTime

  @@id([userId, deviceId])
  @@map("sync_cursors")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Image {
  id            String    @id @default(uuid())
  noteId        String
  userId        String
  filename      String
  mimeType      String
  sizeBytes     Int
  r2Key         String    @unique
  r2Url         String
  altText       String    @default("")
  aiDescription String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  note          Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("images")
}
