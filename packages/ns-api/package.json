{
  "name": "@derekentringer/ns-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "prisma generate && tsx watch --env-file=.env src/index.ts",
    "start": "tsx src/index.ts",
    "type-check": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@derekentringer/shared": "*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.0",
    "fastify": "^5.2.0",
    "ffmpeg-static": "^5.3.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^22.0.0",
    "prisma": "^7.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
