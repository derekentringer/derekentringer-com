{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NoteSync",
  "version": "1.93.18",
  "identifier": "com.derekentringer.notesync",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3006",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "NoteSync",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "txt",
          "markdown"
        ],
        "mimeType": "text/plain",
        "description": "Text Document"
      }
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
