{
  "name": "@derekentringer/ns-desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "vite build",
    "tauri:build": "tauri build",
    "tauri:build:local": "tauri build",
    "tauri:build:prod": "npm run tauri:version-sync && npm run tauri:clear-cache && VITE_API_URL=https://ns-api.derekentringer.com tauri build --target universal-apple-darwin",
    "tauri:version-sync": "node -e \"const fs=require('fs');const v=require('child_process').execSync('git describe --tags --abbrev=0').toString().trim().replace(/^v/,'');const c=JSON.parse(fs.readFileSync('src-tauri/tauri.conf.json','utf8'));c.version=v;fs.writeFileSync('src-tauri/tauri.conf.json',JSON.stringify(c,null,2)+'\\n');\"",
    "tauri:clear-cache": "rm -rf ~/Library/Caches/com.derekentringer.notesync/WebKit ~/Library/WebKit/com.derekentringer.notesync/WebsiteData",
    "type-check": "tsc --noEmit",
    "vite:dev": "vite --port 3006",
    "vite:build": "vite build",
    "vite:build:prod": "vite build --mode production",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@derekentringer/ns-shared": "*",
    "@derekentringer/shared": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "marked": "^17.0.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
